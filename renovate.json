{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:disableMajor",
    "group:allNonMajor",
    "group:definitelyTyped",
    "group:linters",
    "group:monorepos",
    "group:vueMonorepo",
    "group:prismaMonorepo",
    "group:nodeJs",
    "group:jestMonorepo",
    "group:playwrightMonorepo",
    "group:lodashMonorepo",
    "group:recommended",
    ":combinePatchMinorReleases",
    ":enableVulnerabilityAlerts",
    ":maintainLockFilesMonthly",
    ":preserveSemverRanges",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticCommitScope(deps)"
  ],
  "automerge": false,
  "platformAutomerge": true,
  "automergeType": "pr",
  "prConcurrentLimit": 2,
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Always update vulnerable npm packages immediately",
      "matchDatasources": ["npm"],
      "vulnerabilityAlerts": true,
      "minimumReleaseAge": "5 days",
      "groupName": null,
      "prPriority": 100,
      "labels": ["vulnerability"],
      "separateMinorPatch": true,
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "One week stability period for npm packages",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "5 days"
    },
    {
      "description": "Grouped GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions all dependencies",
      "groupSlug": "github actions all",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "JS - group vite",
      "groupName": "vite",
      "minimumReleaseAge": "3 days",
      "matchPackageNames": [
        "/^vite$/",
        "/^@vitejs\\//"
      ]
    },
    {
      "description": "JS - group linters",
      "groupName": "linters",
      "matchPackageNames": [
        "/eslint/",
        "/^@prettier\\//",
        "/^prettier-plugin-/"
      ]
    },
    {
      "description": "JS - puppeteer",
      "groupName": "puppeteer",
      "matchPackageNames": ["/puppeteer/"]
    },
    {
      "description": "JS - group microsoft",
      "groupName": "microsoft",
      "matchPackageNames": ["/msal-node/"]
    },
    {
      "description": "Automerge npm updates",
      "matchManagers": ["npm"],
      "matchFileNames": [
        "backend/**",
        "backend-external/**",
        "frontend/**",
        "admin-frontend/**",
        "doc-gen-service/**"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr",
      "labels": ["automerge", "npm-updates"],
      "minimumReleaseAge": "7 days"     
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "autodiscover": true,
  "autodiscoverFilter": "bcgov/fin-pay-transparency",
  "rebaseWhen": "behind-base-branch"
}
